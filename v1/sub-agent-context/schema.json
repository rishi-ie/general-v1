{
  "name": "sub-agent-context",
  "version": "0.1.0",
  "description": "Sub-Agent Context — persistent cognitive layer for Pi Agent",
  "capabilities": [
    "cognitive-continuity",
    "long-term-memory",
    "context-lineage",
    "goal-tracking",
    "decision-tracking",
    "relationship-memory",
    "cognitive-snapshot",
    "memory-question-routing"
  ],
  "settingsSchema": {
    "type": "object",
    "properties": {
      "storagePath": {
        "type": "string",
        "description": "Path to SAC storage directory"
      },
      "mem0Enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable Mem0 semantic memory integration"
      },
      "autoSnapshot": {
        "type": "boolean",
        "default": true,
        "description": "Auto-generate cognitive snapshot at session start"
      },
      "autoLineage": {
        "type": "boolean",
        "default": true,
        "description": "Auto-create lineage epochs on context compaction"
      },
      "memoryQuestionDetection": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "patterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Patterns that trigger memory question routing"
          }
        }
      },
      "metaMemoryAgent": {
        "type": "string",
        "default": "memory",
        "description": "Sub-agent name for memory synthesis"
      },
      "snapshotFormat": {
        "type": "string",
        "enum": ["concise", "detailed"],
        "default": "concise"
      },
      "maxRecentDecisions": {
        "type": "number",
        "minimum": 5,
        "maximum": 100,
        "default": 20
      }
    }
  }
}
