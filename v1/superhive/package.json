{
  "name": "@general-v1/superhive",
  "version": "0.1.0",
  "description": "Host-side orchestrator for SuperHive — manages and coordinates a fleet of General V1 agents.",
  "type": "extension",
  "main": "extensions/superhive/index.ts",
  "pi": {
    "version": ">=0.1.0",
    "extensions": ["./extensions/superhive/index.ts"]
  },
  "permissions": [
    "network:server",
    "network:client",
    "filesystem:userdir"
  ],
  "dependencies": {
    "ws": "^8.18.0",
    "ajv": "^8.17.0",
    "ulid": "^2.3.0"
