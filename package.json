{
  "name": "general-v1",
  "version": "1.0.0",
  "description": "general v1 — a fully-functional CLI agent built on Pi Agent",
  "private": true,
  "scripts": {
    "setup": "./meta-agent/setup.sh",
    "start": "./meta-agent/run.sh",
    "dev": "./meta-agent/run.sh",
    "check": "./meta-agent/run.sh --check",
    "lint": "biome check v1/integrations && biome check meta-agent/meta-agent-config/extensions/context-manager.ts meta-agent/meta-agent-config/extensions/memory.ts meta-agent/meta-agent-config/extensions/model-router.ts meta-agent/meta-agent-config/extensions/persona.ts",
    "lint:fix": "biome check --write v1/integrations && biome check --write meta-agent/meta-agent-config/extensions/context-manager.ts meta-agent/meta-agent-config/extensions/memory.ts meta-agent/meta-agent-config/extensions/model-router.ts meta-agent/meta-agent-config/extensions/persona.ts",
    "smoke": "./scripts/smoke.sh",
    "clean": "rm -rf meta-agent/.pi meta-agent/pi/node_modules v1/*/node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "mem0ai": "^3.0.10",
    "ulid": "^3.0.2",
    "ws": "^8.21.0"
  }
}
