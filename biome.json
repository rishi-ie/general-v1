{
  "$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "error",
        "useNodejsImportProtocol": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noControlCharactersInRegex": "off",
        "noEmptyInterface": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "files": {
    "include": [
      "v1/**/*.ts",
      "meta-agent/meta-agent-config/**/*.ts",
      "meta-agent/meta-agent-config/**/*.md"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.pi/**",
      "meta-agent/pi/**"
    ]
  }
}
